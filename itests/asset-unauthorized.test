# Alice issues an Asset to Bob (owner).
# Alice attempts to Burn it without being authorized — only the owner can Burn.
#
# RUN: CREATE_ID=$(%dpm submit --submitter %ledger --act-as %alice \
# RUN:   --template '#asset-tests:Asset:Asset' \
# RUN:   --arg issuer=%alice --arg owner=%bob --arg name=GOLD --arg quantity=100) \
# RUN:   && CID=$(%dpm "$CREATE_ID" --submitter %ledger --read-as %alice --print-json \
# RUN:      | %python -c 'import sys,json; d=json.load(sys.stdin); print(next(e["contractId"] for e in d["eventsById"].values() if e.get("contractId")))') \
# RUN:   && %dpm submit --submitter %ledger --act-as %alice \
# RUN:      --template '#asset-tests:Asset:Asset' --choice Burn \
# RUN:      --contract-id "$CID" \
# RUN:      --allow-fail --print-json > %t.json \
# RUN:   && %dpm --completion-file %t.json --daml-yaml %daml-yaml --dar %dar --damlc %damlc --color never | FileCheck %s

# CHECK: DPM trace completion
# CHECK: result:     completion failed
# CHECK: status:     DAML_AUTHORIZATION_ERROR
