# Integration test: duplicate asset name rejection.
#
# Issuer creates an AssetRegistry, issues GOLD once (ok), then tries to issue
# GOLD again — the assertMsg guard rejects it with DAML_FAILURE.
#
# RUN: REG_ID=$(%dpm submit --submitter %ledger --act-as %issuer \
# RUN:   --template '#asset-tests:Asset:AssetRegistry' \
# RUN:   --arg issuer=%issuer --arg activeIds=[]) \
# RUN:   && REG_CID=$(%dpm "$REG_ID" --submitter %ledger --read-as %issuer --print-json \
# RUN:      | %python -c 'import sys,json; d=json.load(sys.stdin); print(next(e["contractId"] for e in d["eventsById"].values() if e.get("contractId")))') \
# RUN:   && ISSUE1_ID=$(%dpm submit --submitter %ledger --act-as %issuer --read-as %alice \
# RUN:      --template '#asset-tests:Asset:AssetRegistry' --choice IssueAsset \
# RUN:      --contract-id "$REG_CID" --arg owner=%alice --arg name=GOLD --arg quantity=100) \
# RUN:   && REG_CID2=$(%dpm "$ISSUE1_ID" --submitter %ledger --read-as %issuer --print-json \
# RUN:      | %python -c 'import sys,json; d=json.load(sys.stdin); print(next(e["contractId"] for e in d["eventsById"].values() if e.get("kind")=="create" and "AssetRegistry" in e.get("template","")))') \
# RUN:   && %dpm submit --submitter %ledger --act-as %issuer --read-as %alice \
# RUN:      --template '#asset-tests:Asset:AssetRegistry' --choice IssueAsset \
# RUN:      --contract-id "$REG_CID2" --arg owner=%alice --arg name=GOLD --arg quantity=50 \
# RUN:      --allow-fail --print-json > %t.json \
# RUN:   && %dpm --completion-file %t.json --daml-yaml %daml-yaml --dar %dar --damlc %damlc --color never | FileCheck %s

# CHECK: DPM trace completion
# CHECK: result:     completion failed
# CHECK: status:     DAML_FAILURE
# CHECK: DUPLICATE_CONTRACT_KEY
# CHECK: Source diagnostics
# CHECK: .daml:{{[0-9]+}}
