# Integration test: double-spend attempt.
#
# Alice creates an Asset and transfers it to Bob.
# The Transfer consumes the original contract; Alice then tries to Burn
# the already-consumed CID — the ledger rejects it.
#
# RUN: CREATE_ID=$(%dpm submit --submitter %ledger --act-as %alice \
# RUN:   --template '#asset-tests:Asset:Asset' \
# RUN:   --arg issuer=%alice --arg owner=%alice --arg name=GOLD --arg quantity=100) \
# RUN:   && CID=$(%dpm "$CREATE_ID" --submitter %ledger --read-as %alice --print-json \
# RUN:      | %python -c 'import sys,json; d=json.load(sys.stdin); print(next(e["contractId"] for e in d["eventsById"].values() if e.get("contractId")))') \
# RUN:   && %dpm submit --submitter %ledger --act-as %alice --read-as %bob \
# RUN:      --template '#asset-tests:Asset:Asset' --choice Transfer \
# RUN:      --contract-id "$CID" --arg newOwner=%bob \
# RUN:   && %dpm submit --submitter %ledger --act-as %alice \
# RUN:      --template '#asset-tests:Asset:Asset' --choice Burn \
# RUN:      --contract-id "$CID" --args-json '{}' \
# RUN:      --allow-fail --print-json > %t.json \
# RUN:   && %dpm --completion-file %t.json --color never | FileCheck %s

# CHECK: DPM trace completion
# CHECK: result:     completion failed
# CHECK: status:     CONTRACT_NOT_FOUND
# CHECK: message:    Contract could not be found
