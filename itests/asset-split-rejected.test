# Integration test (failed submission): exercise Split with an invalid amount on
# the live ledger. The contract's assertMsg rejects it; we capture the rejection
# and dpm trace maps it back to the Asset source line -- the "why did my live
# submission fail" workflow, end to end.
#
# RUN: ID=$(%dpm submit --submitter %ledger --act-as %alice --template '#asset-tests:Asset:Asset' --arg issuer=%alice --arg owner=%alice --arg name=GOLD --arg quantity=100) \
# RUN:   && CID=$(%dpm "$ID" --submitter %ledger --read-as %alice --print-json | %python -c 'import sys,json; d=json.load(sys.stdin); print(next(e["contractId"] for e in d["eventsById"].values() if e.get("contractId")))') \
# RUN:   && %dpm submit --submitter %ledger --act-as %alice --template '#asset-tests:Asset:Asset' --choice Split --contract-id "$CID" --arg splitQuantity=0 --allow-fail --print-json > %t.json \
# RUN:   && %dpm --completion-file %t.json --daml-yaml %daml-yaml --dar %dar --damlc %damlc --color never | FileCheck %s

# CHECK: DPM trace completion
# CHECK: result:     completion failed
# CHECK: splitQuantity must be between 1 and quantity - 1
# CHECK: Source diagnostics
# CHECK: Asset.daml:{{[0-9]+}}
# CHECK: assertMsg "splitQuantity must be between 1 and quantity - 1"
